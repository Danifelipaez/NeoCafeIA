import time
from google import genai
from google.genai import types
from utils import get_api_key

# Usamos las mismas funciones base que te dio tu profesor para el cliente
def _get_client() -> genai.Client:
    return genai.Client(api_key=get_api_key("GEMINI_API_KEY"))

def _get_available_model(client: genai.Client) -> str:
    # Por defecto usamos el recomendado para tu clase
    return "models/gemini-2.5-flash"

# ---------------------------------------------------------------------------
# CONFIGURACIÓN DEL BOT DE LA CAFETERÍA
# ---------------------------------------------------------------------------

# Aquí definimos el menú, precios y promociones
MENU_Y_REGLAS_CAFETERIA = """
Eres el asistente virtual exclusivo de la cafetería "Aroma & Código". 
Tu único objetivo es ayudar a los clientes con información sobre nuestro menú, precios y promociones.

INFORMACIÓN DEL NEGOCIO:
- Nombre: Cafetería Aroma & Código
- Horario: Lunes a Sábado de 7:00 AM a 8:00 PM.

MENÚ Y PRECIOS:
1. Café Espresso: $2.00
2. Café Americano: $2.50
3. Capuchino: $3.50
4. Latte: $3.50
5. Café Frío (Iced Coffee): $4.00
6. Pastel de chocolate (Acompañamiento): $3.00
7. Galleta de avena: $1.50

PROMOCIONES VIGENTES:
- Jueves de Amigos: 2x1 en todos los cafés fríos.
- Combo Mañanero (7 AM a 10 AM): Café Americano + Galleta de avena por solo $3.00.

⚠️ REGLAS ESTRICTAS DE COMPORTAMIENTO (MURO DE CONTENCIÓN):
1. SOLO debes responder preguntas relacionadas con los productos, precios, horarios y promociones de esta cafetería.
2. Si el usuario te pregunta sobre cualquier otro tema (como programación, tareas, fútbol, recetas externas, etc.), debes responder amable pero firmemente: "Lo siento, como asistente de la cafetería Aroma & Código, solo puedo ayudarte con información de nuestro menú, precios y promociones."
3. No inventes productos ni precios que no estén en la lista anterior.
4. Sé siempre amable, cortés y utiliza emojis sutilmente para que la atención sea cálida.
"""

def responder_cliente_cafeteria(historial_conversacion: list[dict]) -> str:
    """
    Envía la conversación completa manteniendo al bot dentro de las reglas de la cafetería.
    
    Args:
        historial_conversacion: Lista de diccionarios con el historial de la charla.
    """
    if not historial_conversacion:
        return "¡Hola! Bienvenido a Aroma & Código. ¿En qué puedo ayudarte hoy?"

    client = _get_client()
    modelo = _get_available_model(client)

    # Convertimos el historial al formato que exige la librería de Google
    contents = []
    for item in historial_conversacion:
        contents.append(
            types.Content(
                role=item.get("role", "user"),
                parts=[types.Part.from_text(text=str(item.get("parts", [""])[0]))]
            )
        )

    # Aquí ocurre la magia: Le pasamos las instrucciones restrictivas
    config = types.GenerateContentConfig(
        system_instruction=MENU_Y_REGLAS_CAFETERIA,
        temperature=0.3, # Temperatura baja para que sea más preciso y no invente cosas
    )

    response = client.models.generate_content(
        model=modelo,
        contents=contents,
        config=config,
    )
    return response.text or ""


# ---------------------------------------------------------------------------
# PRUEBA DE SIMULACIÓN EN CONSOLA
# ---------------------------------------------------------------------------
if __name__ == "__main__":
    print("=== INICIANDO SIMULACIÓN DEL BOT DE LA CAFETERÍA ===")
    
    # Simularemos una conversación guardando el historial como nos enseñó el profe
    historial = []
    
    # Lista de mensajes que un usuario real (o despistado) podría enviar
    mensajes_prueba = [
        "Hola, ¿qué venden y a qué precio?",
        "¿Tienen alguna promoción hoy?",
        "Oye, me dejas una receta para hacer pizza en casa?", # Intento de sacarlo de contexto
        "Ah okay entiendo... ¿y a qué hora abren los sábados?",
        "Genial, gracias por la información."
    ]
    
    for mensaje in mensajes_prueba:
        print(f"\n🗣️ Cliente: {mensaje}")
        
        # 1. Agregamos lo que dice el cliente al historial
        historial.append({"role": "user", "parts": [mensaje]})
        
        # 2. El bot genera la respuesta basada en TODO el historial
        respuesta_bot = responder_cliente_cafeteria(historial)
        
        # 3. Agregamos la respuesta del bot al historial para que no "olvide" el hilo
        historial.append({"role": "model", "parts": [respuesta_bot]})
        
        print(f"🤖 Bot: {respuesta_bot}")
        time.sleep(1) # Pausa dramática para simular tiempo de respuesta                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                